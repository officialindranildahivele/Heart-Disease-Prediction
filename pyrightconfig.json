{
  "typeCheckingMode": "basic",
  "pythonVersion": "3.9",
  "pythonPlatform": "Darwin",
  "include": ["."],
  "exclude": [".venv", "__pycache__", ".venv-old", "**/node_modules", "**/.*"],
  "venvPath": ".",
  "venv": ".venv",
  "reportMissingImports": false,
  "reportMissingTypeStubs": false,
  "reportMissingModuleSource": false
}
